# Required: Secret key for encrypting TOTP secrets and signing sessions
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=

# The username for login (hardcoded single user)
APP_USERNAME=admin

# Turso database connection
# Get these from: turso db create home-control && turso db tokens create home-control
# For local dev, leave blank to use a local SQLite file
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
